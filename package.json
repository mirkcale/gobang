{
  "name": "gobang-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "pnpm -F @gobang/client dev",
    "dev:server": "pnpm -F @gobang/server dev",
    "dev": "run-p \"dev:client \"  \"dev:server\"",
    "build": "pnpm -F @gobang/client build",
    "preview": "pnpm -F @gobang/client preview"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}